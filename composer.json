{
    "name": "do1emu/module-ekkon",
    "description": "Ekkon – Task-System mit Lauf-Historie und MSSQL-Anbindung als Modul für die Intranet-Plattform.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "intranet", "tasks", "scheduler", "mssql"],
    "require": {
        "php": "^8.3"
    },
    "autoload": {
        "psr-4": {
            "Intranet\\Modules\\Ekkon\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Intranet\\Modules\\Ekkon\\EkkonServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
